@model Web.ViewModels.Auth.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="row justify-content-center mt-4">
    <div class="col-md-5">
        <div class="card shadow-sm border-0 rounded-4">
            <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
                <h4 class="fw-bold text-dark mb-0"><i class="bi bi-key-fill me-2 text-warning"></i>Change Password</h4>
            </div>
            <div class="card-body p-4">
                <form asp-action="ChangePassword" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small mb-3 shadow-sm rounded-3"></div>

                    <div class="form-floating mb-3">
                        <input asp-for="CurrentPassword" class="form-control bg-light" placeholder="Current Password" />
                        <label asp-for="CurrentPassword">Current Password</label>
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-3">
                        <input asp-for="NewPassword" class="form-control bg-light" placeholder="New Password" />
                        <label asp-for="NewPassword">New Password</label>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="form-floating mb-4">
                        <input asp-for="ConfirmPassword" class="form-control bg-light" placeholder="Confirm New Password" />
                        <label asp-for="ConfirmPassword">Confirm New Password</label>
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between mt-4 border-top pt-4">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary px-4 fw-bold shadow-sm">Cancel</a>
                        <button type="submit" class="btn btn-success px-4 fw-bold shadow-sm"><i class="bi bi-shield-check me-2"></i>Update Password</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}