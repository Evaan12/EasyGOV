@model Application.Common.Pagination.PagedResult<Domain.Entities.CitizenProfile>
@{
    ViewData["Title"] = "Citizen Profiles";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="bi bi-person-vcard me-2 text-indigo"></i>Citizen Registry</h3>
</div>

<div class="card border-dark rounded-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover table-bordered border-dark align-middle mb-0">
            <thead class="table-dark text-uppercase small">
                <tr>
                    <th class="px-4 py-3 border-dark">Full Name</th>
                    <th class="px-4 py-3 border-dark">Date of Birth</th>
                    <th class="px-4 py-3 border-dark text-center">Status</th>
                    <th class="px-4 py-3 border-dark text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var profile in Model.Items)
                {
                    <tr>
                        <td class="px-4 py-3 fw-bold border-dark">@profile.FullName</td>
                        <td class="px-4 py-3 border-dark">@profile.DateOfBirth.ToString("yyyy-MM-dd")</td>
                        <td class="px-4 py-3 border-dark text-center">
                            @if (profile.Status == Domain.Enums.CitizenStatus.Active)
                            {
                                <span class="badge bg-success border border-success text-white rounded-0 px-3">ACTIVE</span>
                            }
                            else if (profile.Status == Domain.Enums.CitizenStatus.PendingActivation)
                            {
                                <span class="badge bg-warning border border-warning text-dark rounded-0 px-3">PENDING ACTIVATION</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary border border-secondary text-white rounded-0 px-3">PENDING E-KYC</span>
                            }
                        </td>
                        <td class="px-4 py-3 border-dark text-center">
                            @if(profile.Status == Domain.Enums.CitizenStatus.PendingActivation)
                            {
                                <button type="button" class="btn btn-sm btn-dark fw-bold rounded-0 shadow-sm" onclick="openVerifyModal('@profile.Id')">
                                    Verify & Enroll
                                </button>
                            }
                            else
                            {
                                <span class="text-muted small fw-bold">N/A</span>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4 fw-bold">No registered profiles mapped to this hierarchy.</td></tr>
                }
            </tbody>
        </table>
    </div>
    @if(Model.TotalPages > 1)
    {
        <div class="card-footer bg-white border-top border-dark pt-3">
            <pager paged-result="Model"></pager>
        </div>
    }
</div>

<!-- Verify & Enroll Modal -->
<div class="modal fade" id="verifyModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content border-dark rounded-0 shadow-lg text-start">
            <div class="modal-header bg-dark text-white border-bottom border-dark rounded-0">
                <h5 class="modal-title fw-bold"><i class="bi bi-shield-check me-2"></i>Verify & Enroll Citizen</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-0">
                <div class="row g-0">
                    <div class="col-md-6 bg-light p-4 border-end border-dark" style="max-height: 65vh; overflow-y: auto;" id="docsContainer">
                        <!-- Docs loaded here -->
                    </div>
                    <div class="col-md-6 p-4 text-center d-flex flex-column justify-content-between">
                        <form asp-action="EnrollBiometrics" method="post" id="enrollForm">
                            <input type="hidden" name="citizenId" id="verifyCitizenId" />
                            <input type="hidden" name="base64Template" id="base64Template_verify" />
                            
                            <div class="mb-4 pt-3">
                                <i class="bi bi-fingerprint" id="fingerprintIcon_verify" style="font-size: 5rem; color: #6c757d; transition: color 0.5s;"></i>
                                <p class="mt-3 fw-bold text-muted" id="scanStatus_verify">Waiting for scanner interaction...</p>
                            </div>
                            
                            <button type="button" class="btn btn-primary fw-bold rounded-0 px-4 mb-3 w-100" onclick="simulateScanVerify()">Simulate Scan (Demo)</button>
                            <button type="submit" id="submitScan_verify" class="btn btn-success fw-bold rounded-0 w-100 mb-4 py-2" disabled>Finalize Enrollment</button>
                        </form>
                        
                        <div class="border-top border-dark border-dashed pt-4 mt-auto">
                            <form asp-action="RejectEkyc" method="post">
                                <input type="hidden" name="citizenId" id="rejectCitizenId" />
                                <div class="mb-2 text-start">
                                    <label class="fw-bold small text-danger">Discard / Reject Request</label>
                                    <input type="text" name="reason" class="form-control form-control-sm border-danger rounded-0 mb-2" placeholder="Reason for rejection..." required />
                                </div>
                                <button type="submit" class="btn btn-outline-danger fw-bold rounded-0 w-100" onclick="return confirm('Are you sure you want to discard this e-KYC request?');">Reject Request</button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function openVerifyModal(id) {
            document.getElementById('verifyCitizenId').value = id;
            document.getElementById('rejectCitizenId').value = id;
            
            document.getElementById('docsContainer').innerHTML = '<div class="text-center mt-5"><span class="spinner-border spinner-border-sm text-primary"></span> Loading Documents...</div>';
            
            fetch(`/api/citizens/${id}/documents`)
                .then(res => res.json())
                .then(docs => {
                    let html = '';
                    docs.forEach(d => {
                        html += `<div class="mb-4">
                            <strong class="d-block mb-2 text-uppercase text-dark border-bottom border-secondary pb-1">${d.type}</strong>
                            <a href="${d.path}" target="_blank">
                                <img src="${d.path}" alt="${d.name}" class="img-fluid border border-dark rounded-0 shadow-sm" style="max-height: 250px; object-fit: contain; width: 100%; background: #fff;" />
                            </a>
                        </div>`;
                    });
                    document.getElementById('docsContainer').innerHTML = html || '<p class="text-muted fw-bold text-center mt-5">No documents found.</p>';
                });
                
            new bootstrap.Modal(document.getElementById('verifyModal')).show();
        }

        function simulateScanVerify() {
            const icon = document.getElementById('fingerprintIcon_verify');
            const status = document.getElementById('scanStatus_verify');
            const templateInput = document.getElementById('base64Template_verify');
            const submitBtn = document.getElementById('submitScan_verify');
            
            status.innerText = "Scanning Device...";
            icon.style.color = "#0d6efd"; 
            
            setTimeout(() => {
                status.innerText = "Extracting Minutiae Points...";
                icon.style.color = "#ffc107"; 
                
                setTimeout(() => {
                    status.innerText = "Scan Successful! ISO Template ready.";
                    status.classList.replace("text-muted", "text-success");
                    icon.style.color = "#198754"; 
                    templateInput.value = "RkFDRV9UTUxfRFVNTVk="; 
                    submitBtn.disabled = false;
                }, 1500);
            }, 1000);
        }
    </script>
}