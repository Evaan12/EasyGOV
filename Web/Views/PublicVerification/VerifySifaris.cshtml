@model Application.Features.SifarisVerification.Queries.SifarisVerificationResult
@{
    ViewData["Title"] = "Digital Verification Status";
    ViewData["FullWidth"] = true; 
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-10 col-lg-8">
            <div class="card border-dark rounded-0 shadow-lg position-relative" style="background-image: url('https://www.transparenttextures.com/patterns/cubes.png');">
                <div class="card-header bg-dark text-white rounded-0 py-4 text-center border-bottom border-dark">
                    <i class="bi bi-shield-check display-4 mb-2 d-block"></i>
                    <h3 class="fw-bold mb-0 tech-font">OFFICIAL VERIFICATION</h3>
                </div>
                
                <div class="card-body p-5 bg-white text-center position-relative">
                    @if(Model.IsRevoked)
                    {
                        <div class="bg-danger text-white p-4 border border-dark rounded-0 mb-4 shadow-sm position-relative z-1">
                            <i class="bi bi-x-octagon-fill display-5 mb-2 d-block"></i>
                            <h4 class="fw-bold text-uppercase">Document Revoked</h4>
                            <p class="mb-0 fw-bold mt-2 border-top pt-2 border-white">Reason: @Model.RevocationReason</p>
                        </div>
                    }
                    else
                    {
                        <div class="bg-success text-white p-4 border border-dark rounded-0 mb-4 shadow-sm position-relative z-1">
                            <i class="bi bi-check-circle-fill display-5 mb-2 d-block"></i>
                            <h4 class="fw-bold text-uppercase">Verified Authentic</h4>
                        </div>
                    }

                    @if(Model.ProfileChanged && !Model.IsChallengeSuccessful)
                    {
                        <div class="alert alert-warning text-start rounded-0 border-dark shadow-sm py-3 px-4 fw-bold small mt-3 position-relative z-1">
                            <i class="bi bi-exclamation-triangle-fill me-1 text-danger fs-5 align-middle"></i> 
                            Note: The citizen's details have been updated in the master registry since this document was issued.
                            <hr class="border-dark opacity-25 my-2" />
                            <form method="post" action="@Url.Action("VerifySifarisPost", "PublicVerification", new { id = Model.SifarisId })" class="mt-2">
                                <label class="mb-1">Verify current legal name to clear flag:</label>
                                <div class="d-flex">
                                    <input type="text" name="challenge" class="form-control border-dark rounded-0 me-2" placeholder="Enter current Full Name..." required />
                                    <button type="submit" class="btn btn-dark fw-bold rounded-0 px-4">Verify</button>
                                </div>
                            </form>
                        </div>
                    }
                    else if (Model.IsChallengeSuccessful)
                    {
                        <div class="alert alert-success text-start rounded-0 border-dark shadow-sm py-3 px-4 fw-bold small mt-3 position-relative z-1">
                            <i class="bi bi-check-circle-fill me-1 fs-5 align-middle"></i> 
                            Verification Successful: The citizen's current updated legal name is officially <strong class="text-uppercase text-dark">@Model.CurrentFullName</strong>.
                        </div>
                    }

                    <div class="text-start border border-dark p-5 bg-white shadow-sm mt-4 position-relative z-1">
                        <div class="d-flex justify-content-between align-items-start mb-4">
                            <div>
                                <h6 class="text-muted fw-bold text-uppercase mb-1">Document Tracing Analytics</h6>
                                <p class="mb-1 small"><span class="fw-bold">Tracing Node ID:</span> <span class="font-monospace">@Model.SifarisId</span></p>
                            </div>
                            <div class="text-center">
                                <img src="https://api.qrserver.com/v1/create-qr-code/?size=100x100&data=@Url.Action("VerifySifaris", "PublicVerification", new { id = Model.SifarisId }, Context.Request.Scheme)" alt="QR Code" class="border border-dark p-1 bg-white" />
                            </div>
                        </div>

                        <div class="p-4 border border-dark bg-light shadow-sm" style="overflow-x: auto;">
                            @Html.Raw(Model.CompiledHtml)
                        </div>

                        <div class="d-flex justify-content-end mt-5 pt-4">
                            <div class="text-center" style="border-top: 2px dashed #000; padding-top: 10px; width: 250px;">
                                <h5 class="fw-bold mb-0 tech-font text-dark fs-3" style="font-family: 'Great Vibes', cursive;">@Model.ApproverName</h5>
                                <p class="mb-0 text-muted small text-uppercase fw-bold">@Model.ApproverRole</p>
                                <span class="badge bg-danger mt-2 border border-dark text-white rounded-0 px-3 py-1 shadow-sm">AUTHORIZED ISSUER</span>
                            </div>
                        </div>
                    </div>
                    
                    <!-- Watermark -->
                    <div class="position-absolute top-50 start-50 translate-middle" style="opacity: 0.05; pointer-events: none; z-index: 0;">
                        <i class="bi bi-award-fill" style="font-size: 15rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    @@import url('https://fonts.googleapis.com/css2?family=Great+Vibes&display=swap');
</style>