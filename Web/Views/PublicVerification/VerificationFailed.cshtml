@{
    ViewData["Title"] = "Verification Failed";
    ViewData["FullWidth"] = true; 
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6 text-center">
            <i class="bi bi-exclamation-triangle-fill text-danger mb-4" style="font-size: 6rem;"></i>
            <h1 class="display-5 fw-bold text-dark tech-font text-uppercase">Verification Failed</h1>
            <p class="lead fw-bold mt-3 border border-danger bg-white p-4 shadow-sm rounded-0">
                @ViewBag.ErrorMessage
            </p>
            <a href="/" class="btn btn-dark btn-lg mt-4 fw-bold rounded-0 px-5"><i class="bi bi-house-door-fill me-2"></i> Return Home</a>
        </div>
    </div>
</div>