@model Application.Common.Pagination.PagedResult<Domain.Entities.DocumentTemplate>
@{
    ViewData["Title"] = "Sifaris Templates";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="bi bi-file-earmark-code me-2 text-primary"></i>Sifaris Templates</h3>
    <a asp-action="Create" class="btn btn-primary fw-bold shadow-sm"><i class="bi bi-plus-lg me-1"></i> Add Template</a>
</div>

<div class="card border-dark rounded-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover table-bordered border-dark align-middle mb-0">
            <thead class="table-dark text-uppercase small">
                <tr>
                    <th class="px-4 py-3 border-dark">Template Name</th>
                    <th class="px-4 py-3 border-dark">Type</th>
                    <th class="px-4 py-3 border-dark text-center">Scope</th>
                    <th class="px-4 py-3 border-dark">Description</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var template in Model.Items)
                {
                    <tr>
                        <td class="px-4 py-3 fw-bold border-dark">@template.Name</td>
                        <td class="px-4 py-3 border-dark">@template.Type</td>
                        <td class="px-4 py-3 border-dark text-center">
                            @if (template.TenantType == Domain.Enums.TenantType.Central)
                            {
                                <span class="badge bg-success rounded-0">GLOBAL</span>
                            }
                            else
                            {
                                <span class="badge bg-primary rounded-0">LOCAL</span>
                            }
                        </td>
                        <td class="px-4 py-3 border-dark text-muted small">@template.Description</td>
                    </tr>
                }
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="4" class="text-center text-muted py-4 fw-bold">No templates found.</td></tr>
                }
            </tbody>
        </table>
    </div>
    @if(Model.TotalPages > 1)
    {
        <div class="card-footer bg-white border-top border-dark pt-3">
            <pager paged-result="Model"></pager>
        </div>
    }
</div>