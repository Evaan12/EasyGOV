@model IEnumerable<Domain.Entities.MissingPerson>
@{
    ViewData["Title"] = "Public Registry - Missing Persons";
    ViewData["FullWidth"] = true; // Signals layout to utilize expanded view bounds
}

<div class="container py-5">
    <div class="text-center mb-5 border-bottom border-dark pb-4">
        <h1 class="display-4 fw-bold tech-font text-danger text-uppercase mb-3"><i class="bi bi-broadcast me-3"></i>Active Missing Persons List</h1>
        <p class="lead text-muted fw-bold">Real-time public broadcasting grid powered by Central Data Systems.</p>
    </div>

    <div class="row g-4">
        @foreach (var person in Model.Where(m => !m.IsFound))
        {
            <div class="col-md-6 col-lg-4">
                <div class="card border-dark rounded-0 h-100 shadow-sm border-top border-5 border-danger">
                    <div class="card-body p-4 d-flex align-items-center">
                        <div class="bg-dark text-white d-flex justify-content-center align-items-center me-4" style="width: 70px; height: 70px; border-radius: 50%;">
                            <i class="bi bi-person-x fs-1"></i>
                        </div>
                        <div>
                            <h4 class="fw-bold text-uppercase mb-1">@person.FullName</h4>
                            <p class="text-muted small mb-0 font-monospace">ID: @person.Id.ToString().Substring(0, 13)...</p>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(person.Notes))
                    {
                        <div class="card-footer bg-light border-top border-dark p-3 fst-italic text-muted small">
                            <i class="bi bi-quote fs-5 text-secondary"></i> @person.Notes
                        </div>
                    }
                </div>
            </div>
        }

        @if (!Model.Any(m => !m.IsFound))
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-shield-check text-success" style="font-size: 5rem;"></i>
                <h3 class="fw-bold mt-3">All clear. No active alerts at this time.</h3>
            </div>
        }
    </div>
</div>