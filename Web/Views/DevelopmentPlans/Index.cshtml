@model Application.Common.Pagination.PagedResult<Domain.Entities.DevelopmentPlan>
@{
    ViewData["Title"] = "Development Plans";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="bi bi-map me-2 text-success"></i>Development Roadmap</h3>
    <button class="btn btn-success fw-bold rounded-0 shadow-sm" data-bs-toggle="modal" data-bs-target="#createPlanModal">
        <i class="bi bi-plus-lg me-1"></i> Draft New Plan
    </button>
</div>

<div class="row g-4">
    @foreach(var plan in Model.Items)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card border-dark rounded-0 h-100 shadow-sm">
                <div class="card-header bg-dark text-white rounded-0">
                    <h5 class="fw-bold mb-0 text-truncate" title="@plan.Title">@plan.Title</h5>
                </div>
                <div class="card-body p-4 bg-light">
                    <p class="text-muted small border-bottom border-dark pb-3 mb-3" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">@plan.Description</p>
                    <div class="d-flex justify-content-between fw-bold text-dark mb-2 border-bottom border-secondary pb-2">
                        <span>Budget:</span>
                        <span class="text-success">NPR @plan.Budget.ToString("N0")</span>
                    </div>
                    <div class="d-flex justify-content-between fw-bold text-dark">
                        <span>Timeline:</span>
                        <span>@plan.StartDate.ToString("MMM yyyy") - @plan.EndDate.ToString("MMM yyyy")</span>
                    </div>
                </div>
                <div class="card-footer bg-white border-top border-dark text-end p-3 d-flex justify-content-between align-items-center">
                    <span class="badge @(plan.Status == Domain.Enums.PlanStatus.Draft ? "bg-secondary" : plan.Status == Domain.Enums.PlanStatus.Published ? "bg-primary" : plan.Status == Domain.Enums.PlanStatus.Completed ? "bg-success" : "bg-danger") rounded-0 px-3 py-2 border border-dark">@plan.Status.ToString()</span>
                    <div class="btn-group border border-dark shadow-sm">
                        @if (plan.Status == Domain.Enums.PlanStatus.Draft)
                        {
                            <form asp-action="Publish" method="post" class="m-0">
                                <input type="hidden" name="id" value="@plan.Id" />
                                <button type="submit" class="btn btn-sm btn-light fw-bold rounded-0 border-0 border-end border-dark" title="Publish"><i class="bi bi-megaphone-fill text-primary"></i></button>
                            </form>
                        }
                        @if (plan.Status == Domain.Enums.PlanStatus.Published)
                        {
                            <form asp-action="Complete" method="post" class="m-0">
                                <input type="hidden" name="id" value="@plan.Id" />
                                <button type="submit" class="btn btn-sm btn-light fw-bold rounded-0 border-0 border-end border-dark" title="Mark as Completed"><i class="bi bi-check-circle-fill text-success"></i></button>
                            </form>
                        }
                        @if (plan.Status == Domain.Enums.PlanStatus.Draft || plan.Status == Domain.Enums.PlanStatus.Published)
                        {
                            <form asp-action="Cancel" method="post" class="m-0">
                                <input type="hidden" name="id" value="@plan.Id" />
                                <button type="submit" class="btn btn-sm btn-light fw-bold rounded-0 border-0" onclick="return confirm('Cancel this plan? This action cannot be reversed.');" title="Cancel Plan"><i class="bi bi-x-circle-fill text-danger"></i></button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    
    @if(!Model.Items.Any())
    {
        <div class="col-12 text-center text-muted py-5">
            <i class="bi bi-folder-x fs-1"></i>
            <p class="mt-2 fw-bold">No development plans located in this hierarchy.</p>
        </div>
    }
</div>

@if(Model.TotalPages > 1)
{
    <div class="mt-4">
        <pager paged-result="Model"></pager>
    </div>
}

<!-- Create Plan Modal -->
<div class="modal fade" id="createPlanModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-lg modal-dialog-centered">
    <div class="modal-content border-dark rounded-0 shadow-lg">
      <div class="modal-header bg-success text-white border-bottom border-dark rounded-0">
        <h5 class="modal-title fw-bold"><i class="bi bi-map me-2"></i>Draft New Plan</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form asp-action="Create" method="post">
          <div class="modal-body p-4 bg-light text-start">
              <div class="mb-3">
                  <label class="form-label fw-bold text-dark text-uppercase small">Project Title</label>
                  <input type="text" name="title" class="form-control border-dark rounded-0" placeholder="e.g. Ward 6 Road Expansion" required />
              </div>
              <div class="mb-3">
                  <label class="form-label fw-bold text-dark text-uppercase small">Full Description</label>
                  <textarea name="description" class="form-control border-dark rounded-0" rows="4" placeholder="Detail the objectives and expected outcomes of the project..." required></textarea>
              </div>
              <div class="mb-4">
                  <label class="form-label fw-bold text-dark text-uppercase small">Allocated Budget (NPR)</label>
                  <input type="number" name="budget" class="form-control border-dark rounded-0" min="0" placeholder="e.g. 500000" required />
              </div>
              <div class="row g-3 mb-3">
                  <div class="col-md-6">
                      <label class="form-label fw-bold text-dark text-uppercase small">Start Date</label>
                      <input type="date" name="startDate" class="form-control border-dark rounded-0" required />
                  </div>
                  <div class="col-md-6">
                      <label class="form-label fw-bold text-dark text-uppercase small">End Date</label>
                      <input type="date" name="endDate" class="form-control border-dark rounded-0" required />
                  </div>
              </div>
          </div>
          <div class="modal-footer border-top border-dark rounded-0 bg-white">
            <button type="button" class="btn btn-outline-dark fw-bold rounded-0" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-success fw-bold rounded-0 border border-dark">Submit Draft</button>
          </div>
      </form>
    </div>
  </div>
</div>