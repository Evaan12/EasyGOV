@{
    ViewData["Title"] = ViewBag.CanApprove ? "Pending Sifaris Applications" : "Sifaris Document Gateway";
    var pendingAppsForOfficer = ViewBag.PendingApplications as IEnumerable<Domain.Entities.SifarisApplication>;
    var templates = ViewBag.Templates as IEnumerable<Application.Features.DocumentTemplates.Queries.TemplateDto>;
    var myApps = ViewBag.MyApplications as IEnumerable<Domain.Entities.SifarisApplication>;
    var myDocs = ViewBag.MyDocuments as IEnumerable<Domain.Entities.Sifaris>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="bi bi-file-earmark-check me-2 text-primary"></i>@ViewData["Title"]</h3>
    @if (ViewBag.CanApprove)
    {
        <a asp-action="History" class="btn btn-secondary fw-bold rounded-0 shadow-sm">
            <i class="bi bi-clock-history me-1"></i> View History
        </a>
    }
</div>

@if (ViewBag.CanApprove)
{
    <div class="card border-dark shadow-sm rounded-0">
        <div class="table-responsive">
            <table class="table table-hover table-bordered border-dark align-middle mb-0">
                <thead class="table-dark text-uppercase small">
                    <tr>
                        <th class="px-4 py-3 border-dark">Application ID</th>
                        <th class="px-4 py-3 border-dark">Date Submitted</th>
                        <th class="px-4 py-3 border-dark text-center">Status</th>
                        <th class="px-4 py-3 border-dark text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (pendingAppsForOfficer != null && pendingAppsForOfficer.Any())
                    {
                        foreach(var app in pendingAppsForOfficer)
                        {
                            <tr>
                                <td class="px-4 py-3 fw-bold border-dark font-monospace text-muted">@app.Id.ToString().Substring(0,8)</td>
                                <td class="px-4 py-3 border-dark">@app.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                <td class="px-4 py-3 border-dark text-center"><span class="badge bg-warning text-dark border border-warning rounded-0">PENDING</span></td>
                                <td class="px-4 py-3 border-dark text-center">
                                    <a asp-action="Review" asp-route-id="@app.Id" class="btn btn-sm btn-dark fw-bold rounded-0">Process Application</a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="4" class="text-center text-muted py-4 fw-bold">No pending applications at this time.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
else
{
    <ul class="nav nav-tabs border-dark mb-4" id="sifarisTab" role="tablist">
      <li class="nav-item" role="presentation">
        <button class="nav-link active text-dark fw-bold border-dark rounded-0" id="apply-tab" data-bs-toggle="tab" data-bs-target="#apply-tab-pane" type="button" role="tab" aria-controls="apply-tab-pane" aria-selected="true"><i class="bi bi-plus-circle me-1"></i> Apply</button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link text-dark fw-bold border-dark rounded-0" id="pending-tab" data-bs-toggle="tab" data-bs-target="#pending-tab-pane" type="button" role="tab" aria-controls="pending-tab-pane" aria-selected="false"><i class="bi bi-hourglass-split me-1"></i> Pending Apps</button>
      </li>
      <li class="nav-item" role="presentation">
        <button class="nav-link text-dark fw-bold border-dark rounded-0" id="issued-tab" data-bs-toggle="tab" data-bs-target="#issued-tab-pane" type="button" role="tab" aria-controls="issued-tab-pane" aria-selected="false"><i class="bi bi-award me-1"></i> Issued Documents</button>
      </li>
    </ul>

    <div class="tab-content" id="sifarisTabContent">
      <div class="tab-pane fade show active" id="apply-tab-pane" role="tabpanel" aria-labelledby="apply-tab" tabindex="0">
          <div class="row g-4">
             <div class="col-md-5">
                 <div class="card border-dark shadow-sm rounded-0 border-top border-4 border-warning h-100">
                     <div class="card-header bg-dark text-white rounded-0 py-3">
                         <h5 class="mb-0 fw-bold"><i class="bi bi-file-earmark-plus me-2 text-warning"></i> Available Certificates</h5>
                     </div>
                     <div class="card-body bg-light p-4">
                         <ul class="list-group rounded-0 border-dark">
                             @if(templates != null && templates.Any())
                             {
                                 foreach(var t in templates)
                                 {
                                     <li class="list-group-item d-flex justify-content-between align-items-center border-dark p-3">
                                         <div>
                                              <span class="fw-bold d-block text-dark text-uppercase">@t.Name</span>
                                              <small class="text-muted">@t.Description</small>
                                         </div>
                                         <button class="btn btn-sm btn-warning border-dark rounded-0 fw-bold shadow-sm" onclick="openApplyModal('@t.Id')">View & Apply</button>
                                     </li>
                                 }
                             }
                             else
                             {
                                 <li class="list-group-item text-muted fw-bold p-4 text-center">No structural templates published by the Ward yet.</li>
                             }
                         </ul>
                     </div>
                 </div>
             </div>
             <div class="col-md-7">
                  <div class="card border-dark shadow-sm rounded-0 border-top border-4 border-primary h-100">
                      <div class="card-body p-5 text-center d-flex flex-column justify-content-center align-items-center">
                          <i class="bi bi-folder-check text-primary mb-3" style="font-size: 5rem;"></i>
                          <h2 class="fw-bold text-dark tech-font">Sifaris Workspace</h2>
                          <p class="text-muted fw-bold mb-4">Official Document Lifecycle Pipeline</p>
                          <div class="alert alert-info border-dark rounded-0 shadow-sm w-100 text-start">
                              <i class="bi bi-info-circle-fill me-2 text-info fs-5 align-middle"></i> 
                              The digital Sifaris pipeline natively routes generated documentation based on localized hierarchical workflow rules.
                              <br/><br/>
                              <strong>Note:</strong> Select a certificate template from the left. You will be required to fill out the associated <strong>Application (Nibedan)</strong> to initiate the request.
                          </div>
                      </div>
                  </div>
             </div>
          </div>
      </div>
      
      <div class="tab-pane fade" id="pending-tab-pane" role="tabpanel" aria-labelledby="pending-tab" tabindex="0">
          <div class="card border-dark shadow-sm rounded-0">
              <div class="table-responsive">
                  <table class="table table-hover table-bordered border-dark align-middle mb-0">
                      <thead class="table-dark text-uppercase small">
                          <tr>
                              <th class="px-4 py-3 border-dark">Application ID</th>
                              <th class="px-4 py-3 border-dark">Date Submitted</th>
                              <th class="px-4 py-3 border-dark text-center">Status</th>
                          </tr>
                      </thead>
                      <tbody>
                          @if (myApps != null && myApps.Any())
                          {
                              foreach(var app in myApps)
                              {
                                  <tr>
                                      <td class="px-4 py-3 fw-bold border-dark font-monospace text-muted">@app.Id.ToString().Substring(0,8)</td>
                                      <td class="px-4 py-3 border-dark">@app.CreatedAt.ToString("MMM dd, yyyy HH:mm")</td>
                                      <td class="px-4 py-3 border-dark text-center">
                                          @if(app.Status == Domain.Enums.ApplicationStatus.PendingReview)
                                          {
                                              <span class="badge bg-warning text-dark border border-warning rounded-0">PENDING</span>
                                          }
                                          else if(app.Status == Domain.Enums.ApplicationStatus.Rejected)
                                          {
                                              <span class="badge bg-danger text-white border border-danger rounded-0">REJECTED</span>
                                              <p class="small text-muted mt-1 mb-0 text-start border-top pt-1 border-dark">@app.ReviewNotes</p>
                                          }
                                          else if(app.Status == Domain.Enums.ApplicationStatus.Approved)
                                          {
                                              <span class="badge bg-success text-white border border-success rounded-0">APPROVED</span>
                                          }
                                      </td>
                                  </tr>
                              }
                          }
                          else
                          {
                              <tr><td colspan="3" class="text-center text-muted py-4 fw-bold">You have no applications.</td></tr>
                          }
                      </tbody>
                  </table>
              </div>
          </div>
      </div>
      
      <div class="tab-pane fade" id="issued-tab-pane" role="tabpanel" aria-labelledby="issued-tab" tabindex="0">
          <div class="row g-4">
              @if (myDocs != null && myDocs.Any())
              {
                  foreach(var doc in myDocs)
                  {
                      <div class="col-md-4">
                          <div class="card border-dark rounded-0 h-100 shadow-sm border-top border-4 border-success">
                              <div class="card-body p-4 text-center">
                                  <i class="bi bi-award text-success fs-1 mb-3 d-block"></i>
                                  <h5 class="fw-bold text-dark text-uppercase">Approved Sifaris</h5>
                                  <p class="text-muted small font-monospace">@doc.Id.ToString().Substring(0,13)...</p>
                                  <p class="text-muted small mb-0 border-top border-dark pt-2 mt-2">Issued: @doc.CreatedAt.ToString("MMM dd, yyyy")</p>
                              </div>
                              <div class="card-footer bg-white border-top border-dark p-0">
                                  <a asp-controller="Sifaris" asp-action="Document" asp-route-id="@doc.Id" class="btn btn-light w-100 rounded-0 fw-bold py-3 text-success text-uppercase border-0"><i class="bi bi-eye-fill me-2"></i> View Document</a>
                              </div>
                          </div>
                      </div>
                  }
              }
              else
              {
                  <div class="col-12 text-center text-muted py-5">
                      <i class="bi bi-folder-x fs-1"></i>
                      <p class="mt-2 fw-bold">You have no issued Sifaris documents.</p>
                  </div>
              }
          </div>
      </div>
    </div>
}

<!-- Apply Modal (Nibedan Form) -->
<div class="modal fade" id="applyModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-dark rounded-0 shadow-lg">
      <div class="modal-header bg-warning text-dark border-bottom border-dark rounded-0">
        <h5 class="modal-title fw-bold" id="applyModalTitle">Application Form (Nibedan)</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form id="dynamicForm" onsubmit="previewDynamicForm(event)">
          <div class="modal-body p-4 bg-light" id="dynamicFormFields">
              <div class="text-center my-4"><span class="spinner-border spinner-border-sm text-primary"></span> Loading Application Data...</div>
          </div>
          <div class="modal-footer border-top border-dark rounded-0 bg-white">
            <button type="button" class="btn btn-outline-dark fw-bold rounded-0" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary fw-bold rounded-0 border-dark">Review Nibedan <i class="bi bi-arrow-right"></i></button>
          </div>
      </form>
    </div>
  </div>
</div>

<!-- Preview Modal (Nibedan Preview) -->
<div class="modal fade" id="previewModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-xl modal-dialog-centered">
    <div class="modal-content border-dark rounded-0 shadow-lg">
      <div class="modal-header bg-dark text-white border-bottom border-dark rounded-0">
        <h5 class="modal-title fw-bold"><i class="bi bi-eye-fill me-2"></i>Application (Nibedan) Review</h5>
        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-0 bg-secondary" style="overflow-x: auto;">
          <div class="alert alert-warning border-0 rounded-0 mb-0 fw-bold text-center">
              <i class="bi bi-info-circle me-1"></i> This is the application you are submitting to the Ward Office.
          </div>
          <div id="previewContainer" class="p-5 d-flex justify-content-center">
              <div class="text-center my-5"><span class="spinner-border text-white"></span></div>
          </div>
      </div>
      <div class="modal-footer border-top border-dark rounded-0 bg-white">
        <button type="button" class="btn btn-outline-dark fw-bold rounded-0" data-bs-target="#applyModal" data-bs-toggle="modal">Back to Edit</button>
        <button type="button" class="btn btn-success fw-bold rounded-0" onclick="document.getElementById('actualSubmitForm').submit();">Submit Application</button>
      </div>
    </div>
  </div>
</div>

<form id="actualSubmitForm" asp-action="Submit" method="post" class="d-none">
    <input type="hidden" name="targetSifarisTemplateId" id="actualTargetSifarisTemplateId" />
    <input type="hidden" name="nibedanTemplateId" id="actualNibedanTemplateId" />
    <input type="hidden" name="jsonData" id="jsonDataPayload" />
</form>

@section Scripts {
    <script>
        function openApplyModal(sifarisTemplateId) {
            document.getElementById('actualTargetSifarisTemplateId').value = sifarisTemplateId;
            document.getElementById('dynamicFormFields').innerHTML = '<div class="text-center my-4"><span class="spinner-border spinner-border-sm text-primary"></span> Loading Application Data...</div>';
            new bootstrap.Modal(document.getElementById('applyModal')).show();
            
            fetch(`/api/sifaris/nibedan-template/${sifarisTemplateId}`)
                .then(async res => {
                    const data = await res.json();
                    if (!res.ok) throw new Error(data.message || 'Failed to load application schema.');
                    return data;
                })
                .then(data => {
                    document.getElementById('actualNibedanTemplateId').value = data.templateId;
                    
                    const schema = JSON.parse(data.prefilledSchemaJson);
                    const container = document.getElementById('dynamicFormFields');
                    container.innerHTML = `<p class="text-muted small fw-bold mb-4 border-bottom border-dark pb-2">Filling application for: <span class="text-dark">${data.name}</span></p>`;
                    
                    schema.fields.forEach(f => {
                        container.innerHTML += `<div class="mb-3">
                            <label class="form-label fw-bold">${f.label}</label>
                            <input type="${f.type}" name="${f.name}" class="form-control rounded-0 border-dark" value="${f.defaultValue || ''}" required />
                        </div>`;
                    });
                })
                .catch(err => {
                    document.getElementById('dynamicFormFields').innerHTML = `<div class="alert alert-danger fw-bold rounded-0 border-dark"><i class="bi bi-exclamation-triangle-fill me-2"></i>${err.message}</div>`;
                });
        }

        function previewDynamicForm(e) {
            e.preventDefault();
            const form = e.target;
            const formData = new FormData(form);
            const dataObj = {};
            for (let [key, val] of formData.entries()) {
                dataObj[key] = val;
            }
            const jsonData = JSON.stringify(dataObj);
            document.getElementById('jsonDataPayload').value = jsonData;
            
            const nibedanTemplateId = document.getElementById('actualNibedanTemplateId').value;
            
            // Show loading on preview container
            document.getElementById('previewContainer').innerHTML = '<div class="text-center my-5"><span class="spinner-border text-white" style="width: 3rem; height: 3rem;"></span><p class="text-white mt-3 fw-bold">Compiling Draft...</p></div>';
            
            // Swap modals
            const applyModalEl = document.getElementById('applyModal');
            const previewModalEl = document.getElementById('previewModal');
            bootstrap.Modal.getInstance(applyModalEl).hide();
            new bootstrap.Modal(previewModalEl).show();
            
            fetch(`/api/sifaris/preview?templateId=${nibedanTemplateId}`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: jsonData
            })
            .then(res => {
                if(!res.ok) throw new Error("Failed to compile preview");
                return res.text();
            })
            .then(html => {
                document.getElementById('previewContainer').innerHTML = `<div class="bg-white border border-dark shadow" style="min-width: 800px; padding: 3rem;">${html}</div>`;
            })
            .catch(err => {
                document.getElementById('previewContainer').innerHTML = `<div class="alert alert-danger fw-bold rounded-0 border-dark m-5"><i class="bi bi-exclamation-triangle-fill me-2"></i>${err.message}</div>`;
            });
        }
    </script>
}