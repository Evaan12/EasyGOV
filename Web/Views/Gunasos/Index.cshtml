@model Application.Common.Pagination.PagedResult<Domain.Entities.Gunaso>
@{
    ViewData["Title"] = ViewBag.IsCitizenView ? "My Grievances" : "Grievance Management (Gunaso)";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="bi bi-envelope-paper me-2 text-warning"></i>@ViewData["Title"]</h3>
    
    @if(ViewBag.IsCitizenView)
    {
        <button class="btn btn-warning fw-bold rounded-0 border-dark shadow-sm" data-bs-toggle="modal" data-bs-target="#fileGunasoModal">
            <i class="bi bi-pencil-square me-1"></i> File New Grievance
        </button>
    }
</div>

<div class="row g-4">
    @foreach(var item in Model.Items)
    {
        <div class="col-md-6 col-xl-4">
            <div class="card border-dark rounded-0 h-100 shadow-sm border-top border-4 border-warning">
                <div class="card-body p-4 bg-light">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <h5 class="fw-bold text-dark text-truncate mb-0" title="@item.Title">@item.Title</h5>
                        <span class="badge bg-dark rounded-0">@item.Status.ToString()</span>
                    </div>
                    
                    <p class="small text-muted mb-3 border-bottom border-dark pb-3" style="display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;">
                        @item.Description
                    </p>

                    <div class="d-flex justify-content-between align-items-center mb-0">
                        <span class="fw-bold text-uppercase small" style="color: @(item.Severity == Domain.Enums.GunasoSeverity.Critical ? "red" : "black");">
                            Severity: @item.Severity
                        </span>
                        
                        @if(item.Status != Domain.Enums.GunasoStatus.Resolved && item.Status != Domain.Enums.GunasoStatus.Closed && !ViewBag.IsCitizenView && User.Identity?.IsAuthenticated == true)
                        {
                            <button class="btn btn-sm btn-dark fw-bold rounded-0" data-bs-toggle="modal" data-bs-target="#resolveModal_@item.Id">Resolve</button>
                            
                            <!-- Resolution Modal Instance -->
                            <div class="modal fade" id="resolveModal_@item.Id" tabindex="-1" aria-hidden="true">
                              <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content border-dark rounded-0">
                                  <div class="modal-header bg-dark text-white border-bottom border-dark rounded-0">
                                    <h5 class="modal-title fw-bold"><i class="bi bi-check-circle me-2 text-success"></i>Resolve Grievance</h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                  </div>
                                  <form asp-action="Resolve" method="post">
                                      <input type="hidden" name="id" value="@item.Id" />
                                      <div class="modal-body p-4 bg-light text-start">
                                          <div class="mb-3">
                                              <label class="form-label fw-bold text-dark">Resolution Notes / Findings</label>
                                              <textarea name="resolutionNotes" class="form-control border-dark rounded-0" rows="4" required></textarea>
                                          </div>
                                      </div>
                                      <div class="modal-footer border-top border-dark rounded-0 bg-white">
                                        <button type="button" class="btn btn-outline-dark fw-bold rounded-0" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-success fw-bold rounded-0">Confirm Resolution</button>
                                      </div>
                                  </form>
                                </div>
                              </div>
                            </div>
                        }
                    </div>
                </div>
                
                @if(item.Status == Domain.Enums.GunasoStatus.Resolved && !string.IsNullOrEmpty(item.ResolutionNotes))
                {
                    <div class="card-footer bg-success bg-opacity-10 border-top border-success p-3">
                        <strong class="text-success small d-block mb-1">Official Resolution:</strong>
                        <p class="text-dark small mb-0 fst-italic">@item.ResolutionNotes</p>
                    </div>
                }
            </div>
        </div>
    }

    @if(!Model.Items.Any())
    {
        <div class="col-12 text-center text-muted py-5">
            <i class="bi bi-inboxes fs-1"></i>
            <p class="mt-2 fw-bold">No grievances logged at this tier.</p>
        </div>
    }
</div>

@if(Model.TotalPages > 1)
{
    <div class="mt-4">
        <pager paged-result="Model"></pager>
    </div>
}

@if(ViewBag.IsCitizenView)
{
    <!-- File Gunaso Modal -->
    <div class="modal fade" id="fileGunasoModal" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-dark rounded-0 shadow-lg">
          <div class="modal-header bg-warning text-dark border-bottom border-dark rounded-0">
            <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square me-2"></i>File New Grievance</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <form asp-action="FileGunaso" method="post">
              <div class="modal-body p-4 bg-light text-start">
                  <div class="alert alert-info border-dark rounded-0 small fw-bold shadow-sm">
                      <i class="bi bi-robot me-2"></i> Your grievance text will be automatically structured, translated to formal Nepali, and categorized by AI before submission.
                  </div>
                  <div class="mb-3">
                      <label class="form-label fw-bold text-dark">Target Authority Node</label>
                      <select name="targetTenantId" class="form-select border-dark rounded-0" asp-items="ViewBag.Tenants" required>
                          <option value="">-- Select Authority --</option>
                      </select>
                      <div class="form-text small">Select the vertical hierarchy entity you wish to address.</div>
                  </div>
                  <div class="mb-3">
                      <label class="form-label fw-bold text-dark">Grievance Description</label>
                      <textarea name="rawText" class="form-control border-dark rounded-0" rows="5" placeholder="Explain your issue in plain text..." required></textarea>
                  </div>
              </div>
              <div class="modal-footer border-top border-dark rounded-0 bg-white">
                <button type="button" class="btn btn-outline-dark fw-bold rounded-0" data-bs-dismiss="modal">Cancel</button>
                <button type="submit" class="btn btn-warning fw-bold rounded-0 border-dark">Process & Submit</button>
              </div>
          </form>
        </div>
      </div>
    </div>
}