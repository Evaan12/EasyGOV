@model Application.Common.Pagination.PagedResult<Application.Features.Tenants.DTOs.TenantDto>
@{
    ViewData["Title"] = "Tenant Hierarchy";
    var availableRoles = ViewBag.AvailableRoles as List<Application.Features.Roles.DTOs.RoleDto>;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="fw-bold mb-0 text-dark"><i class="bi bi-diagram-3 me-2 text-primary"></i>Tenant Organizations</h3>
</div>

<div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-4">
    <div class="card-body bg-light border-bottom p-3">
        <form method="get" class="row g-2">
            <div class="col-md-2">
                <input type="text" name="SearchTerm" class="form-control fw-bold border-dark" placeholder="Search by name..." value="@ViewBag.SearchTerm" />
            </div>
            <div class="col-md-2">
                <select name="tenantType" class="form-select border-dark" onchange="this.form.submit()">
                    <option value="">-- All Tiers --</option>
                    @foreach (var type in Enum.GetValues<Domain.Enums.TenantType>())
                    {
                        if (ViewBag.TenantType != null && (Domain.Enums.TenantType)ViewBag.TenantType == type)
                        {
                            <option value="@((int)type)" selected>@type.ToString()</option>
                        }
                        else
                        {
                            <option value="@((int)type)">@type.ToString()</option>
                        }
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="isActivated" class="form-select border-dark" onchange="this.form.submit()">
                    <option value="">-- All Status --</option>
                    @if (ViewBag.IsActivated == true)
                    {
                        <option value="true" selected>Active</option>
                        <option value="false">Dormant</option>
                    }
                    else if (ViewBag.IsActivated == false)
                    {
                        <option value="true">Active</option>
                        <option value="false" selected>Dormant</option>
                    }
                    else
                    {
                        <option value="true">Active</option>
                        <option value="false">Dormant</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select name="provinceId" id="provinceId" class="form-select border-dark" asp-items="ViewBag.ProvinceList" onchange="document.getElementById('districtId').value=''; document.getElementById('municipalityId').value=''; this.form.submit()">
                    <option value="">-- Province --</option>
                </select>
            </div>
            <div class="col-md-2">
                <select name="districtId" id="districtId" class="form-select border-dark" asp-items="ViewBag.DistrictList" onchange="document.getElementById('municipalityId').value=''; this.form.submit()" disabled="@(ViewBag.ProvinceId == null ? "disabled" : null)">
                    <option value="">-- District --</option>
                </select>
            </div>
            <div class="col-md-1">
                <select name="municipalityId" id="municipalityId" class="form-select border-dark" asp-items="ViewBag.MunicipalityList" onchange="this.form.submit()" disabled="@(ViewBag.DistrictId == null ? "disabled" : null)">
                    <option value="">-- Muni. --</option>
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary w-100 fw-bold px-0 border-dark"><i class="bi bi-filter me-1"></i> Go</button>
            </div>
            
            @if (Model.PageNumber > 1)
            {
                <input type="hidden" name="PageNumber" value="@Model.PageNumber" />
            }
        </form>
    </div>
</div>

<div class="card border-dark rounded-0 shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover table-bordered border-dark align-middle mb-0">
            <thead class="table-dark text-uppercase small">
                <tr>
                    <th class="px-4 py-3 border-dark">Tenant Name</th>
                    <th class="px-4 py-3 border-dark">Tier</th>
                    <th class="px-4 py-3 border-dark">Parent Org</th>
                    <th class="px-4 py-3 border-dark text-center">Status</th>
                    <th class="px-4 py-3 border-dark text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr>
                        <td class="px-4 py-3 fw-bold border-dark">@item.Name</td>
                        <td class="px-4 py-3 border-dark"><span class="badge bg-secondary rounded-0">@item.TenantType</span></td>
                        <td class="px-4 py-3 border-dark text-muted">@(item.ParentName ?? "- Root -")</td>
                        <td class="px-4 py-3 border-dark text-center">
                            @if (item.IsActivated)
                            {
                                <span class="badge bg-success border border-success text-white rounded-0">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-warning border border-warning text-dark rounded-0">Dormant</span>
                            }
                        </td>
                        <td class="px-4 py-3 border-dark text-center">
                            
                            <button type="button" class="btn btn-sm btn-outline-primary fw-bold rounded-0 me-1" data-bs-toggle="modal" data-bs-target="#editModal_@item.Id">
                                Edit
                            </button>
                            
                            <!-- Edit Tenant Modal -->
                            <div class="modal fade" id="editModal_@item.Id" tabindex="-1" aria-hidden="true">
                              <div class="modal-dialog modal-dialog-centered">
                                <div class="modal-content border-dark rounded-0 shadow-lg text-start">
                                  <div class="modal-header bg-primary text-white border-bottom border-dark rounded-0">
                                    <h5 class="modal-title fw-bold"><i class="bi bi-pencil-square me-2"></i>Update Tenant Details</h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                  </div>
                                  <form asp-action="Update" method="post">
                                      <input type="hidden" name="tenantId" value="@item.Id" />
                                      <div class="modal-body p-4 bg-light">
                                          <div class="mb-3">
                                              <label class="form-label fw-bold">Tenant Name</label>
                                              <input type="text" name="name" class="form-control rounded-0 border-dark" value="@item.Name" required />
                                          </div>
                                      </div>
                                      <div class="modal-footer border-top border-dark rounded-0 bg-white">
                                        <button type="button" class="btn btn-outline-dark fw-bold rounded-0" data-bs-dismiss="modal">Cancel</button>
                                        <button type="submit" class="btn btn-primary fw-bold rounded-0">Save Changes</button>
                                      </div>
                                  </form>
                                </div>
                              </div>
                            </div>

                            @if (item.IsActivated)
                            {
                                <form asp-action="ToggleStatus" method="post" class="d-inline m-0">
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <input type="hidden" name="activate" value="false" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger fw-bold rounded-0" onclick="return confirm('Are you sure you want to deactivate this tenant?');">
                                        Deactivate
                                    </button>
                                </form>
                            }
                            else
                            {
                                <button type="button" class="btn btn-sm btn-outline-success fw-bold rounded-0" data-bs-toggle="modal" data-bs-target="#activateModal_@item.Id">
                                    Activate & Provision
                                </button>
                                
                                <!-- Activate & Provision Modal -->
                                <div class="modal fade" id="activateModal_@item.Id" tabindex="-1" aria-hidden="true">
                                  <div class="modal-dialog modal-dialog-centered">
                                    <div class="modal-content border-dark rounded-0 shadow-lg text-start">
                                      <div class="modal-header bg-success text-white border-bottom border-dark rounded-0">
                                        <h5 class="modal-title fw-bold"><i class="bi bi-shield-check me-2"></i>Activate & Provision Head</h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                      </div>
                                      <form asp-action="ActivateTenant" method="post">
                                          <input type="hidden" name="tenantId" value="@item.Id" />
                                          <div class="modal-body p-4 bg-light">
                                              <div class="alert alert-info border-dark rounded-0 shadow-sm small fw-bold">
                                                  Activating <span class="text-uppercase text-danger">@item.Name</span> requires assigning an initial organizational head (e.g. Mayor, Chairperson) to manage localized operations.
                                              </div>
                                              
                                              <div class="mb-3">
                                                  <label class="form-label fw-bold">Head Full Name</label>
                                                  <input type="text" name="headFullName" class="form-control rounded-0 border-dark" placeholder="John Doe" required />
                                              </div>
                                              
                                              <div class="mb-3">
                                                  <label class="form-label fw-bold">Head Email Address</label>
                                                  <input type="email" name="headEmail" class="form-control rounded-0 border-dark" placeholder="head@gov.np" required />
                                              </div>

                                              <div class="mb-3">
                                                  <label class="form-label fw-bold">Temporary Password</label>
                                                  <input type="password" name="headPassword" class="form-control rounded-0 border-dark" placeholder="Strong Password" required />
                                              </div>

                                              <div class="mb-3">
                                                  <label class="form-label fw-bold">Assign Governing Role</label>
                                                  <select name="headRoleId" class="form-select rounded-0 border-dark" required>
                                                      <option value="">-- Select Template Role --</option>
                                                      @if(availableRoles != null)
                                                      {
                                                          @foreach(var role in availableRoles.Where(r => r.TenantType == item.TenantType))
                                                          {
                                                              <option value="@role.Id">@role.Name</option>
                                                          }
                                                      }
                                                  </select>
                                              </div>
                                          </div>
                                          <div class="modal-footer border-top border-dark rounded-0 bg-white">
                                            <button type="button" class="btn btn-outline-dark fw-bold rounded-0" data-bs-dismiss="modal">Cancel</button>
                                            <button type="submit" class="btn btn-success fw-bold rounded-0">Initialize Tenant</button>
                                          </div>
                                      </form>
                                    </div>
                                  </div>
                                </div>
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Items.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4 fw-bold">No tenants available in this tier matching filters.</td></tr>
                }
            </tbody>
        </table>
    </div>
    @if(Model.TotalPages > 1)
    {
        <div class="card-footer bg-white border-top border-dark pt-3">
            <pager paged-result="Model"></pager>
        </div>
    }
</div>