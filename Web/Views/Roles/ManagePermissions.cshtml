@model Web.ViewModels.Roles.ManagePermissionsViewModel
@using Domain.Enums
@{
    ViewData["Title"] = "Manage Access Control Configurations";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h3 class="fw-bold mb-1 text-dark"><i class="bi bi-shield-lock-fill me-2 text-primary"></i>Permission Constraints</h3>
        <p class="text-muted mb-0">Configuring Access Rights and Restrictions for Role: <strong class="text-primary fs-5">@Model.RoleName</strong></p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary fw-bold shadow-sm"><i class="bi bi-arrow-left me-1"></i> Back to Roles</a>
</div>

<form asp-action="ManagePermissions" method="post">
    <input type="hidden" asp-for="RoleId" />

    <div class="row g-4 mb-4">
        @for (int i = 0; i < Model.Resources.Count; i++)
        {
            <div class="col-md-6 col-lg-6 resource-row">
                <div class="card shadow-sm border-dark rounded-0 h-100">
                    <div class="card-header bg-dark text-white rounded-0 py-3 d-flex justify-content-between align-items-center">
                        <div>
                            <input type="hidden" asp-for="Resources[i].Resource" />
                            <input type="hidden" asp-for="Resources[i].ResourceName" />
                            <input type="hidden" asp-for="Resources[i].AvailableActions" />
                            <h5 class="fw-bold mb-0 text-uppercase"><i class="bi bi-folder-symlink-fill me-2 text-warning"></i>@Model.Resources[i].ResourceName</h5>
                        </div>
                        
                        <!-- High Level Aggregate Bundle Toggles -->
                        <div class="d-flex gap-2">
                            @if (Model.Resources[i].AvailableActions.HasFlag(ActionType.Read | ActionType.Create | ActionType.Update | ActionType.Delete))
                            {
                                <div class="form-check form-switch m-0">
                                    <input type="checkbox" asp-for="Resources[i].CanCrud" class="form-check-input shadow-sm bundle-crud" title="Bundle: Full CRUD" />
                                    <label class="form-check-label text-white small fw-bold" asp-for="Resources[i].CanCrud">CRUD</label>
                                </div>
                            }
                            @if (Model.Resources[i].AvailableActions.HasFlag(ActionType.Admin))
                            {
                                <div class="form-check form-switch m-0 ms-2">
                                    <input type="checkbox" asp-for="Resources[i].CanAdmin" class="form-check-input shadow-sm border-danger bundle-admin" title="Bundle: Admin Override" />
                                    <label class="form-check-label text-danger small fw-bold" asp-for="Resources[i].CanAdmin">ADMIN</label>
                                </div>
                            }
                        </div>
                    </div>

                    <div class="card-body bg-light p-4 border-top border-dark border-3">
                        <h6 class="fw-bold text-secondary mb-3 text-uppercase small">Granular Actions</h6>
                        <div class="d-flex flex-wrap gap-3 mb-4">
                            @if (!Model.Resources[i].AvailableActions.HasFlag(ActionType.Read | ActionType.Create | ActionType.Update | ActionType.Delete))
                            {
                                @if (Model.Resources[i].AvailableActions.HasFlag(ActionType.Read))
                                {
                                    <div class="form-check">
                                        <input type="checkbox" asp-for="Resources[i].CanRead" class="form-check-input shadow-sm" />
                                        <label class="form-check-label user-select-none fw-bold" asp-for="Resources[i].CanRead">Read</label>
                                    </div>
                                }
                                @if (Model.Resources[i].AvailableActions.HasFlag(ActionType.Create))
                                {
                                    <div class="form-check">
                                        <input type="checkbox" asp-for="Resources[i].CanCreate" class="form-check-input shadow-sm" />
                                        <label class="form-check-label user-select-none fw-bold" asp-for="Resources[i].CanCreate">Create</label>
                                    </div>
                                }
                                @if (Model.Resources[i].AvailableActions.HasFlag(ActionType.Update))
                                {
                                    <div class="form-check">
                                        <input type="checkbox" asp-for="Resources[i].CanUpdate" class="form-check-input shadow-sm" />
                                        <label class="form-check-label user-select-none fw-bold" asp-for="Resources[i].CanUpdate">Update</label>
                                    </div>
                                }
                                @if (Model.Resources[i].AvailableActions.HasFlag(ActionType.Delete))
                                {
                                    <div class="form-check">
                                        <input type="checkbox" asp-for="Resources[i].CanDelete" class="form-check-input shadow-sm border-danger" />
                                        <label class="form-check-label user-select-none text-danger fw-bold" asp-for="Resources[i].CanDelete">Delete</label>
                                    </div>
                                }
                            }

                            @if (Model.Resources[i].AvailableActions.HasFlag(ActionType.Export))
                            {
                                <div class="form-check">
                                    <input type="checkbox" asp-for="Resources[i].CanExport" class="form-check-input shadow-sm" />
                                    <label class="form-check-label user-select-none fw-bold" asp-for="Resources[i].CanExport">Export</label>
                                </div>
                            }
                            @if (Model.Resources[i].AvailableActions.HasFlag(ActionType.Approve))
                            {
                                <div class="form-check">
                                    <input type="checkbox" asp-for="Resources[i].CanApprove" class="form-check-input shadow-sm border-warning" />
                                    <label class="form-check-label user-select-none fw-bold text-warning" style="text-shadow: 0px 0px 1px black;" asp-for="Resources[i].CanApprove">Approve</label>
                                </div>
                            }
                            @if (Model.Resources[i].AvailableActions.HasFlag(ActionType.Assign))
                            {
                                <div class="form-check">
                                    <input type="checkbox" asp-for="Resources[i].CanAssign" class="form-check-input shadow-sm border-primary" />
                                    <label class="form-check-label user-select-none text-primary fw-bold" asp-for="Resources[i].CanAssign">Assign</label>
                                </div>
                            }
                            @if (Model.Resources[i].AvailableActions.HasFlag(ActionType.Activate))
                            {
                                <div class="form-check">
                                    <input type="checkbox" asp-for="Resources[i].CanActivate" class="form-check-input shadow-sm border-info" />
                                    <label class="form-check-label user-select-none text-info fw-bold" asp-for="Resources[i].CanActivate">Activate</label>
                                </div>
                            }
                        </div>

                        <hr class="text-dark border-2 opacity-100" />
                        <h6 class="fw-bold text-dark mb-3 text-uppercase small">Execution Constraints (Optional)</h6>

                        <div class="mb-3">
                            <label class="form-label text-muted small fw-bold" asp-for="Resources[i].AllowedIpAddress">Allowed IP Address</label>
                            <input asp-for="Resources[i].AllowedIpAddress" class="form-control rounded-0 border-dark" placeholder="e.g. 192.168.1.100" />
                        </div>

                        <div class="row g-2">
                            <div class="col-6">
                                <label class="form-label text-muted small fw-bold" asp-for="Resources[i].StartTime">Start Time</label>
                                <input asp-for="Resources[i].StartTime" class="form-control rounded-0 border-dark" type="time" />
                            </div>
                            <div class="col-6">
                                <label class="form-label text-muted small fw-bold" asp-for="Resources[i].EndTime">End Time</label>
                                <input asp-for="Resources[i].EndTime" class="form-control rounded-0 border-dark" type="time" />
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="d-flex justify-content-end mb-5 bg-white p-3 border border-dark shadow-sm position-sticky bottom-0" style="z-index: 1020;">
        <button type="submit" class="btn btn-dark btn-lg px-5 fw-bold rounded-0 shadow-none">
            <i class="bi bi-shield-check me-2"></i> Lock-In Security Matrix
        </button>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const rows = document.querySelectorAll('.resource-row');
            
            rows.forEach((row) => {
                const bundleAdmin = row.querySelector('.bundle-admin');
                const allChecks = Array.from(row.querySelectorAll('.form-check-input:not(.bundle-admin)'));

                const updateRowState = () => {
                    const isAdmin = bundleAdmin && bundleAdmin.checked;

                    // Reset disabled state first
                    allChecks.forEach(chk => { chk.disabled = false; });

                    if (isAdmin) {
                        // Admin overrides everything - check and lock down the rest
                        allChecks.forEach(chk => { chk.checked = true; chk.disabled = true; });
                    }
                };

                if (bundleAdmin) bundleAdmin.addEventListener('change', updateRowState);

                // Run on load
                updateRowState();
                
                // Important: Before submit, we must re-enable checkboxes so their values post to the server!
                row.closest('form').addEventListener('submit', () => {
                    allChecks.forEach(chk => { chk.disabled = false; });
                });
            });
        });
    </script>
}
